# Copy to .env and fill in values (never commit .env).

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/auth/strava/callback

SUPABASE_URL=
# Dashboard → Settings → API → Secret keys → Reveal → paste exact key (sb_secret_* is often ~41 chars)
# Invalid API key = wrong/revoked key or masked preview — not the full revealed string.
SUPABASE_SERVICE_KEY=

# openssl rand -hex 32
JWT_SECRET=

# Comma-separated. Add Vercel URL after deploy, e.g. https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# Where to send the browser after Strava login (no trailing slash)
FRONTEND_URL=http://localhost:5173
